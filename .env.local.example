# ─── Stripe (optional — without these keys the app runs in mock mode) ──────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── Vercel KV (auto-injected when you add a KV store in Vercel dashboard) ─────
# Leave blank in local development — the app uses local JSON files instead.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ─── Email (Resend) ────────────────────────────────────────────────────────────
# Sign up at https://resend.com → create API key → paste here
# Without this key, booking confirmation emails are silently skipped.
RESEND_API_KEY=re_...

# Your admin email — receives BCC of every booking confirmation
ADMIN_EMAIL=yuetongma0107@gmail.com

# Full public URL of this site (used in email links)
# In Vercel this is auto-set; for local dev set it manually.
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app
