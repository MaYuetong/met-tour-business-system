# Stripe (required for payment processing)
# Get your keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Webhook Secret (for production webhooks)
# STRIPE_WEBHOOK_SECRET=whsec_...

# Without Stripe keys, the app runs in "mock mode":
# payments are simulated and bookings are saved directly to local JSON.

# ─── Email Notifications (required for review alerts) ─────────────────────────
# Your Gmail address
EMAIL_USER=yuetongma0107@gmail.com
# Gmail App Password (NOT your regular Gmail password)
# How to get one: Google Account → Security → 2-Step Verification → App Passwords
# Generate a new app password for "Mail" → copy the 16-character code here
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
