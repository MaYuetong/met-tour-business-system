# ─── Stripe (optional — without these keys the app runs in mock mode) ──────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── Vercel KV (auto-injected when you add a KV store in Vercel dashboard) ─────
# Leave blank in local development — the app uses local JSON files instead.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ─── Email Notifications ───────────────────────────────────────────────────────
# Handled by Formspree (https://formspree.io/f/xbdwojzk)
# No configuration needed — notifications fire automatically on review submit.
